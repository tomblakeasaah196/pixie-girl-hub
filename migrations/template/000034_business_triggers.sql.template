-- ============================================================
-- TEMPLATE 000034 — Per-business triggers
-- Pixie Girl Hub · JBS Praxis · V2.0
--
-- Triggers that enforce invariants and maintain denormalised
-- summaries in this brand schema:
--
--   • stock_movements:        maintain stock_levels + flag low-stock
--   • stock_levels:           CHECK no negative available
--   • journal_lines:          enforce debit/credit balance per entry
--   • journal_entries:        immutable when posted
--   • invoices:               update status from amount_paid_ngn
--   • sales_order_payments:   update sales_orders.amount_paid_ngn
--   • sales_orders:           append state history on status change
--   • purchase_orders:        append state history on status change
--   • production_runs:        recompute landed cost on cost_components change
--   • service_jobs:           auto-create task when assigned
--   • cost_components:        roll up into production_runs totals
--   • commission_earned:      auto-attribute from sales_orders
--   • document_numbering:     atomic increment
-- ============================================================

-- ╔════════════════════════════════════════════════════════════════════╗
-- ║ STOCK MOVEMENTS → STOCK LEVELS                                     ║
-- ╚════════════════════════════════════════════════════════════════════╝

CREATE OR REPLACE FUNCTION {{BUSINESS}}.fn_apply_stock_movement()
RETURNS TRIGGER
LANGUAGE plpgsql AS $$
BEGIN
  -- 'reserve' moves on_hand → reserved (no net change); 'release_reserve' reverses
  IF NEW.movement_type = 'reserve' THEN
    INSERT INTO {{BUSINESS}}.stock_levels (variant_id, location_id, on_hand, reserved, last_movement_at)
    VALUES (NEW.variant_id, NEW.location_id, 0, ABS(NEW.quantity), NEW.performed_at)
    ON CONFLICT (variant_id, location_id) DO UPDATE
      SET reserved = {{BUSINESS}}.stock_levels.reserved + ABS(EXCLUDED.reserved),
          last_movement_at = EXCLUDED.last_movement_at,
          updated_at = now();
  ELSIF NEW.movement_type = 'release_reserve' THEN
    UPDATE {{BUSINESS}}.stock_levels
       SET reserved = GREATEST(0, reserved - ABS(NEW.quantity)),
           last_movement_at = NEW.performed_at,
           updated_at = now()
     WHERE variant_id = NEW.variant_id AND location_id = NEW.location_id;
  ELSE
    -- Net stock change at this location
    INSERT INTO {{BUSINESS}}.stock_levels (variant_id, location_id, on_hand, last_movement_at)
    VALUES (NEW.variant_id, NEW.location_id, NEW.quantity, NEW.performed_at)
    ON CONFLICT (variant_id, location_id) DO UPDATE
      SET on_hand = {{BUSINESS}}.stock_levels.on_hand + EXCLUDED.on_hand,
          last_movement_at = EXCLUDED.last_movement_at,
          updated_at = now();
  END IF;
  RETURN NEW;
END;
$$;

CREATE TRIGGER trg_{{BUSINESS}}_apply_stock_movement
  AFTER INSERT ON {{BUSINESS}}.stock_movements
  FOR EACH ROW EXECUTE FUNCTION {{BUSINESS}}.fn_apply_stock_movement();

-- ╔════════════════════════════════════════════════════════════════════╗
-- ║ JOURNAL: enforce debit = credit per entry                          ║
-- ╚════════════════════════════════════════════════════════════════════╝

CREATE OR REPLACE FUNCTION {{BUSINESS}}.fn_journal_entry_balance_check()
RETURNS TRIGGER
LANGUAGE plpgsql AS $$
DECLARE
  v_dr NUMERIC(14,2);
  v_cr NUMERIC(14,2);
BEGIN
  IF NEW.status = 'posted' AND (OLD IS NULL OR OLD.status <> 'posted') THEN
    SELECT COALESCE(SUM(debit_ngn),0), COALESCE(SUM(credit_ngn),0)
      INTO v_dr, v_cr
      FROM {{BUSINESS}}.journal_lines
     WHERE entry_id = NEW.entry_id;
    IF ROUND(v_dr,2) <> ROUND(v_cr,2) THEN
      RAISE EXCEPTION 'Journal entry % is unbalanced: debits=% credits=%',
        NEW.entry_number, v_dr, v_cr;
    END IF;
    -- Lock totals on the entry to match
    NEW.total_debit_ngn := v_dr;
    NEW.total_credit_ngn := v_cr;
  END IF;
  RETURN NEW;
END;
$$;

CREATE TRIGGER trg_{{BUSINESS}}_journal_entry_balance
  BEFORE UPDATE OF status ON {{BUSINESS}}.journal_entries
  FOR EACH ROW EXECUTE FUNCTION {{BUSINESS}}.fn_journal_entry_balance_check();

-- ── Journal entries: immutable when posted ───────────────
CREATE OR REPLACE FUNCTION {{BUSINESS}}.fn_journal_entry_immutable()
RETURNS TRIGGER
LANGUAGE plpgsql AS $$
BEGIN
  -- Once 'posted', only status -> 'reversed' / 'void' is allowed; everything else frozen
  IF OLD.status = 'posted' AND NEW.status NOT IN ('reversed','void','posted') THEN
    -- 'posted' -> 'posted' allowed (no-op updates); 'reversed','void' allowed
    NULL;
  ELSIF OLD.status = 'posted' THEN
    -- Field-level immutability
    IF OLD.entry_number     <> NEW.entry_number     THEN RAISE EXCEPTION 'entry_number is immutable when posted'; END IF;
    IF OLD.posting_date     <> NEW.posting_date     THEN RAISE EXCEPTION 'posting_date is immutable when posted'; END IF;
    IF OLD.total_debit_ngn  <> NEW.total_debit_ngn  THEN RAISE EXCEPTION 'total_debit_ngn is immutable when posted'; END IF;
    IF OLD.total_credit_ngn <> NEW.total_credit_ngn THEN RAISE EXCEPTION 'total_credit_ngn is immutable when posted'; END IF;
  END IF;
  RETURN NEW;
END;
$$;

CREATE TRIGGER trg_{{BUSINESS}}_journal_entry_immutable
  BEFORE UPDATE ON {{BUSINESS}}.journal_entries
  FOR EACH ROW EXECUTE FUNCTION {{BUSINESS}}.fn_journal_entry_immutable();

-- ── Journal lines: cannot be added to a posted entry ─────
CREATE OR REPLACE FUNCTION {{BUSINESS}}.fn_journal_lines_no_change_when_posted()
RETURNS TRIGGER
LANGUAGE plpgsql AS $$
DECLARE
  v_status TEXT;
BEGIN
  SELECT status INTO v_status FROM {{BUSINESS}}.journal_entries
    WHERE entry_id = COALESCE(NEW.entry_id, OLD.entry_id);
  IF v_status = 'posted' THEN
    RAISE EXCEPTION 'Cannot modify lines of a posted journal entry';
  END IF;
  RETURN COALESCE(NEW, OLD);
END;
$$;

CREATE TRIGGER trg_{{BUSINESS}}_journal_lines_protect
  BEFORE INSERT OR UPDATE OR DELETE ON {{BUSINESS}}.journal_lines
  FOR EACH ROW EXECUTE FUNCTION {{BUSINESS}}.fn_journal_lines_no_change_when_posted();

-- ╔════════════════════════════════════════════════════════════════════╗
-- ║ INVOICE: maintain amount_paid_ngn from invoice_payments            ║
-- ╚════════════════════════════════════════════════════════════════════╝

CREATE OR REPLACE FUNCTION {{BUSINESS}}.fn_invoice_recompute_paid()
RETURNS TRIGGER
LANGUAGE plpgsql AS $$
DECLARE
  v_invoice_id UUID;
  v_paid       NUMERIC(14,2);
  v_total      NUMERIC(14,2);
  v_net_due    NUMERIC(14,2);
  v_new_status TEXT;
BEGIN
  v_invoice_id := COALESCE(NEW.invoice_id, OLD.invoice_id);

  SELECT COALESCE(SUM(amount_applied_ngn),0)
    INTO v_paid
    FROM {{BUSINESS}}.invoice_payments
   WHERE invoice_id = v_invoice_id;

  SELECT total_ngn, net_due_ngn
    INTO v_total, v_net_due
    FROM {{BUSINESS}}.invoices
   WHERE invoice_id = v_invoice_id;

  -- Decide status
  v_new_status := CASE
    WHEN v_paid <= 0                THEN NULL                                 -- don't change current status
    WHEN v_paid >= v_net_due        THEN 'paid'
    WHEN v_paid > 0                 THEN 'partially_paid'
    ELSE NULL
  END;

  UPDATE {{BUSINESS}}.invoices
     SET amount_paid_ngn = v_paid,
         status = COALESCE(v_new_status, status),
         updated_at = now()
   WHERE invoice_id = v_invoice_id;

  RETURN COALESCE(NEW, OLD);
END;
$$;

CREATE TRIGGER trg_{{BUSINESS}}_invoice_payment_recompute
  AFTER INSERT OR UPDATE OR DELETE ON {{BUSINESS}}.invoice_payments
  FOR EACH ROW EXECUTE FUNCTION {{BUSINESS}}.fn_invoice_recompute_paid();

-- ╔════════════════════════════════════════════════════════════════════╗
-- ║ SALES ORDER: maintain amount_paid_ngn from sales_order_payments    ║
-- ╚════════════════════════════════════════════════════════════════════╝

CREATE OR REPLACE FUNCTION {{BUSINESS}}.fn_sales_order_recompute_paid()
RETURNS TRIGGER
LANGUAGE plpgsql AS $$
DECLARE
  v_order_id        UUID;
  v_paid            NUMERIC(14,2);
  v_total           NUMERIC(14,2);
  v_required_dep    NUMERIC(14,2);
  v_last_pay        TIMESTAMPTZ;
  v_now             TIMESTAMPTZ := now();
BEGIN
  v_order_id := COALESCE(NEW.order_id, OLD.order_id);

  -- Sum captured/authorised payments
  SELECT COALESCE(SUM(amount_ngn),0), MAX(recorded_at)
    INTO v_paid, v_last_pay
    FROM {{BUSINESS}}.sales_order_payments
   WHERE order_id = v_order_id
     AND status IN ('captured','authorised');

  -- Read order totals & policy
  SELECT total_ngn, required_deposit_ngn
    INTO v_total, v_required_dep
    FROM {{BUSINESS}}.sales_orders
   WHERE order_id = v_order_id;

  -- B-2: Update paid amount + the three timestamp flags. Once set
  -- (NOT NULL), each timestamp is sticky — we don't re-clear them on
  -- a refund (refunds get their own flow via cancellation_requests).
  UPDATE {{BUSINESS}}.sales_orders
     SET amount_paid_ngn  = v_paid,
         last_payment_at  = COALESCE(v_last_pay, last_payment_at),
         deposit_met_at   = COALESCE(
           deposit_met_at,
           CASE WHEN payment_model = 'deposit_triggered'
                  AND v_required_dep IS NOT NULL
                  AND v_paid >= v_required_dep
                THEN v_now ELSE NULL END
         ),
         fully_paid_at    = COALESCE(
           fully_paid_at,
           CASE WHEN v_paid >= v_total THEN v_now ELSE NULL END
         ),
         updated_at       = v_now
   WHERE order_id = v_order_id;

  RETURN COALESCE(NEW, OLD);
END;
$$;

CREATE TRIGGER trg_{{BUSINESS}}_sales_order_payment_recompute
  AFTER INSERT OR UPDATE OR DELETE ON {{BUSINESS}}.sales_order_payments
  FOR EACH ROW EXECUTE FUNCTION {{BUSINESS}}.fn_sales_order_recompute_paid();

-- ╔════════════════════════════════════════════════════════════════════╗
-- ║ B-2: MANUAL-PAYMENT GUARD                                          ║
-- ║ Staff cannot record a manual bank-transfer payment unless the      ║
-- ║ business_config toggle is ON AND a bank_transaction_id is supplied.║
-- ║ Enforces V2.2 §6.2 separation of duties.                           ║
-- ╚════════════════════════════════════════════════════════════════════╝

CREATE OR REPLACE FUNCTION {{BUSINESS}}.fn_validate_manual_payment()
RETURNS TRIGGER
LANGUAGE plpgsql AS $$
DECLARE
  v_toggle BOOLEAN;
BEGIN
  -- Only inspect manual / staff-recorded bank transfers
  IF NEW.payment_path = 'staff_recorded' OR NEW.method = 'bank_transfer' THEN
    SELECT allow_staff_recorded_manual_payments
      INTO v_toggle
      FROM shared.business_config
     WHERE business_key = '{{BUSINESS}}';

    IF v_toggle IS NOT TRUE THEN
      RAISE EXCEPTION 'Staff-recorded manual payments are disabled in business_config. Toggle on once Finance is hired.';
    END IF;

    IF NEW.manual_bank_transaction_id IS NULL OR NEW.manual_bank_transaction_id = '' THEN
      RAISE EXCEPTION 'manual_bank_transaction_id is mandatory for staff-recorded payments (V2.2 §6.2)';
    END IF;
  END IF;
  RETURN NEW;
END;
$$;

CREATE TRIGGER trg_{{BUSINESS}}_validate_manual_payment
  BEFORE INSERT OR UPDATE ON {{BUSINESS}}.sales_order_payments
  FOR EACH ROW EXECUTE FUNCTION {{BUSINESS}}.fn_validate_manual_payment();

-- ╔════════════════════════════════════════════════════════════════════╗
-- ║ SALES ORDER: append state history on status change                 ║
-- ╚════════════════════════════════════════════════════════════════════╝

CREATE OR REPLACE FUNCTION {{BUSINESS}}.fn_sales_order_log_state()
RETURNS TRIGGER
LANGUAGE plpgsql AS $$
BEGIN
  IF OLD.status IS DISTINCT FROM NEW.status THEN
    INSERT INTO {{BUSINESS}}.sales_order_state_history
      (order_id, from_status, to_status, changed_by_source, changed_at)
    VALUES
      (NEW.order_id, OLD.status, NEW.status, 'system', now());
  END IF;
  RETURN NEW;
END;
$$;

CREATE TRIGGER trg_{{BUSINESS}}_sales_order_log_state
  AFTER UPDATE OF status ON {{BUSINESS}}.sales_orders
  FOR EACH ROW EXECUTE FUNCTION {{BUSINESS}}.fn_sales_order_log_state();

