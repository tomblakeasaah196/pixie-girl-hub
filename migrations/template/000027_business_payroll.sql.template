-- ── payroll_runs ─────────────────────────────────────────
CREATE TABLE {{BUSINESS}}.payroll_runs (
  run_id                UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
  run_number            TEXT        NOT NULL UNIQUE,            -- 'PXG-PAY-2026-05'
  -- Period
  fiscal_period_id      UUID        REFERENCES {{BUSINESS}}.fiscal_periods (period_id) ON DELETE SET NULL,
  pay_month             SMALLINT    NOT NULL CHECK (pay_month BETWEEN 1 AND 12),
  pay_year              SMALLINT    NOT NULL,
  pay_date              DATE        NOT NULL,
  period_start          DATE        NOT NULL,
  period_end            DATE        NOT NULL,
  -- Counts
  total_staff           INTEGER     NOT NULL DEFAULT 0,
  -- Totals (NGN)
  total_gross_ngn       NUMERIC(14,2) NOT NULL DEFAULT 0,
  total_commission_ngn  NUMERIC(14,2) NOT NULL DEFAULT 0,
  total_bonus_ngn       NUMERIC(14,2) NOT NULL DEFAULT 0,
  total_paye_ngn        NUMERIC(14,2) NOT NULL DEFAULT 0,
  total_pension_employee_ngn NUMERIC(14,2) NOT NULL DEFAULT 0,
  total_pension_employer_ngn NUMERIC(14,2) NOT NULL DEFAULT 0,
  total_nhf_ngn         NUMERIC(14,2) NOT NULL DEFAULT 0,
  total_other_deductions_ngn NUMERIC(14,2) NOT NULL DEFAULT 0,
  total_net_ngn         NUMERIC(14,2) NOT NULL DEFAULT 0,
  -- Lifecycle
  status                TEXT        NOT NULL DEFAULT 'draft'
                        CHECK (status IN ('draft','calculated','reviewed','approved','paid','reversed','disputed')),
  workflow_instance_id  UUID        REFERENCES shared.workflow_instances (instance_id) ON DELETE SET NULL,
  calculated_at         TIMESTAMPTZ,
  approved_by           UUID        REFERENCES shared.users (user_id) ON DELETE SET NULL,
  approved_at           TIMESTAMPTZ,
  paid_at               TIMESTAMPTZ,
  -- Journal posting
  journal_entry_id      UUID        REFERENCES {{BUSINESS}}.journal_entries (entry_id) ON DELETE SET NULL,
  -- Documents
  payroll_summary_doc_id UUID       REFERENCES shared.documents (document_id) ON DELETE SET NULL,
  bank_schedule_doc_id  UUID        REFERENCES shared.documents (document_id) ON DELETE SET NULL,
  -- Audit
  notes                 TEXT,
  created_by            UUID        REFERENCES shared.users (user_id) ON DELETE SET NULL,
  created_at            TIMESTAMPTZ NOT NULL DEFAULT now(),
  updated_at            TIMESTAMPTZ NOT NULL DEFAULT now(),
  UNIQUE (pay_year, pay_month)
);
CREATE TRIGGER trg_{{BUSINESS}}_payroll_runs_updated_at
  BEFORE UPDATE ON {{BUSINESS}}.payroll_runs
  FOR EACH ROW EXECUTE FUNCTION shared.fn_set_updated_at();
CREATE INDEX idx_{{BUSINESS}}_payroll_runs_period
  ON {{BUSINESS}}.payroll_runs (pay_year, pay_month);
CREATE INDEX idx_{{BUSINESS}}_payroll_runs_status
  ON {{BUSINESS}}.payroll_runs (status, pay_date DESC);

-- Wire deferred FKs
ALTER TABLE {{BUSINESS}}.commission_earned
  ADD CONSTRAINT fk_{{BUSINESS}}_commission_earned_payroll
    FOREIGN KEY (payroll_run_id) REFERENCES {{BUSINESS}}.payroll_runs (run_id) ON DELETE SET NULL;
ALTER TABLE {{BUSINESS}}.bonuses_awarded
  ADD CONSTRAINT fk_{{BUSINESS}}_bonuses_awarded_payroll
    FOREIGN KEY (payroll_run_id) REFERENCES {{BUSINESS}}.payroll_runs (run_id) ON DELETE SET NULL;

-- ── payslips ─────────────────────────────────────────────
CREATE TABLE {{BUSINESS}}.payslips (
  payslip_id            UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
  payslip_number        TEXT        NOT NULL UNIQUE,            -- 'PXG-SLP-0001'
  payroll_run_id        UUID        NOT NULL REFERENCES {{BUSINESS}}.payroll_runs (run_id) ON DELETE CASCADE,
  user_id               UUID        NOT NULL REFERENCES shared.users (user_id),
  staff_profile_id      UUID        REFERENCES shared.staff_profiles (profile_id) ON DELETE SET NULL,
  -- Snapshot of staff context at time of run
  job_title_snapshot    TEXT,
  department_snapshot   TEXT,
  bank_account_snapshot TEXT,
  bank_sort_code_snapshot TEXT,
  -- Earnings (NGN)
  base_salary_ngn       NUMERIC(14,2) NOT NULL DEFAULT 0,
  allowances_ngn        NUMERIC(14,2) NOT NULL DEFAULT 0,
  commission_ngn        NUMERIC(14,2) NOT NULL DEFAULT 0,
  bonus_ngn             NUMERIC(14,2) NOT NULL DEFAULT 0,
  overtime_ngn          NUMERIC(14,2) NOT NULL DEFAULT 0,
  reimbursements_ngn    NUMERIC(14,2) NOT NULL DEFAULT 0,
  gross_pay_ngn         NUMERIC(14,2) NOT NULL,
  -- Deductions
  paye_ngn              NUMERIC(14,2) NOT NULL DEFAULT 0,
  pension_employee_ngn  NUMERIC(14,2) NOT NULL DEFAULT 0,
  pension_employer_ngn  NUMERIC(14,2) NOT NULL DEFAULT 0,
  nhf_ngn               NUMERIC(14,2) NOT NULL DEFAULT 0,
  loan_repayment_ngn    NUMERIC(14,2) NOT NULL DEFAULT 0,
  advance_recovery_ngn  NUMERIC(14,2) NOT NULL DEFAULT 0,
  other_deductions_ngn  NUMERIC(14,2) NOT NULL DEFAULT 0,
  total_deductions_ngn  NUMERIC(14,2) NOT NULL DEFAULT 0,
  -- Net
  net_pay_ngn           NUMERIC(14,2) NOT NULL,
  -- Payment execution
  payment_status        TEXT        NOT NULL DEFAULT 'pending'
                        CHECK (payment_status IN ('pending','queued','paid','failed','reversed')),
  payment_method        TEXT,
  payment_reference     TEXT,
  paid_at               TIMESTAMPTZ,
  failure_reason        TEXT,
  -- Document
  payslip_pdf_doc_id    UUID        REFERENCES shared.documents (document_id) ON DELETE SET NULL,
  sent_at               TIMESTAMPTZ,
  -- Audit
  created_at            TIMESTAMPTZ NOT NULL DEFAULT now(),
  updated_at            TIMESTAMPTZ NOT NULL DEFAULT now(),
  UNIQUE (payroll_run_id, user_id)
);
CREATE TRIGGER trg_{{BUSINESS}}_payslips_updated_at
  BEFORE UPDATE ON {{BUSINESS}}.payslips
  FOR EACH ROW EXECUTE FUNCTION shared.fn_set_updated_at();
CREATE INDEX idx_{{BUSINESS}}_payslips_run
  ON {{BUSINESS}}.payslips (payroll_run_id);
CREATE INDEX idx_{{BUSINESS}}_payslips_user
  ON {{BUSINESS}}.payslips (user_id, created_at DESC);

-- ── payslip_lines ────────────────────────────────────────
-- Per-payslip line detail (each earning and deduction itemised).
CREATE TABLE {{BUSINESS}}.payslip_lines (
  line_id               UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
  payslip_id            UUID        NOT NULL REFERENCES {{BUSINESS}}.payslips (payslip_id) ON DELETE CASCADE,
  -- Type
  line_type             TEXT        NOT NULL
                        CHECK (line_type IN ('base_salary','housing_allowance','transport_allowance',
                                             'commission','bonus','overtime','reimbursement','other_earning',
                                             'paye','pension_employee','pension_employer','nhf','nsitf',
                                             'loan_repayment','advance_recovery','other_deduction')),
  description           TEXT        NOT NULL,
  -- Amount (positive for earning, positive for deduction — the line_type drives sign)
  amount_ngn            NUMERIC(14,2) NOT NULL CHECK (amount_ngn >= 0),
  -- Linked source
  source_type           TEXT,                                   -- 'commission_earned','bonuses_awarded','cash_advance', etc.
  source_id             UUID,
  -- GL hint
  account_id            UUID        REFERENCES {{BUSINESS}}.chart_of_accounts (account_id) ON DELETE SET NULL,
  display_order         SMALLINT    NOT NULL DEFAULT 0,
  notes                 TEXT
);
CREATE INDEX idx_{{BUSINESS}}_payslip_lines_payslip
  ON {{BUSINESS}}.payslip_lines (payslip_id);
CREATE INDEX idx_{{BUSINESS}}_payslip_lines_source
  ON {{BUSINESS}}.payslip_lines (source_type, source_id) WHERE source_id IS NOT NULL;

-- ── payroll_deductions ───────────────────────────────────
-- The configurable tax / pension / NHF tables used by the payroll
-- engine. PAYE is progressive in Nigeria (consolidated relief
-- allowance + tax bands).
CREATE TABLE {{BUSINESS}}.payroll_deductions (
  deduction_id          UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
  deduction_type        TEXT        NOT NULL
                        CHECK (deduction_type IN ('paye','pension_employee','pension_employer','nhf','nsitf','other')),
  -- Effective period
  effective_from        DATE        NOT NULL,
  effective_to          DATE,
  -- Calculation config
  rate_pct              NUMERIC(7,4),                            -- flat rate (pension, nhf)
  -- Progressive bands (PAYE): [{lower:0, upper:300000, rate:0.07}, ...]
  bands                 JSONB,
  -- Consolidated relief allowance (NGN) for PAYE
  consolidated_relief_ngn NUMERIC(14,2),
  consolidated_relief_pct NUMERIC(7,4),
  -- Caps
  min_taxable_ngn       NUMERIC(14,2),
  max_taxable_ngn       NUMERIC(14,2),
  is_active             BOOLEAN     NOT NULL DEFAULT true,
  notes                 TEXT,
  created_at            TIMESTAMPTZ NOT NULL DEFAULT now()
);
CREATE INDEX idx_{{BUSINESS}}_payroll_deductions_active
  ON {{BUSINESS}}.payroll_deductions (deduction_type, effective_from DESC)
  WHERE is_active = true;

