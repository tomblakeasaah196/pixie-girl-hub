# ============================================================
# PIXIE GIRL HUB — BACKEND ENVIRONMENT VARIABLES
# Copy to .env and fill in real values. NEVER commit .env to git.
# ============================================================

# ── App ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=7000
APP_NAME=pixiegirl-hub-backend
APP_URL=http://localhost:7000
LOG_LEVEL=info
RLS_READ_ENFORCE=false

# ── PostgreSQL ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=xxxxxxxxx
DB_USER=xxxxxxxxxxx
DB_PASSWORD=xxxxxxxx
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_SSL=false
DB_STATEMENT_TIMEOUT_MS=30000

# ── Redis (cache, sessions, BullMQ queue) ───────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Authentication ──────────────────────────────────────────
JWT_SECRET=long_string_random
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=14d
SESSION_SECRET=another_long_string_random
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
COOKIE_SECURE=false
COOKIE_DOMAIN=localhost

# ── Encryption (AES-256 for credentials at rest) ────────────
# MUST be exactly 32 bytes hex-encoded (64 hex chars). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=long_string_random

# ── Password reset ──────────────────────────────────────────
# Lifetime (minutes) of a password-reset link. Single-use; stored only as a
# SHA-256 hash in Redis.
PASSWORD_RESET_TTL_MIN=30

# ── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3001
TRUSTED_PROXIES=loopback,linklocal,uniquelocal

# ── Rate limiting (public / unauthenticated write endpoints) ─
# Per-IP throttle for checkout, newsletter signup, hair-quiz, e-sign submit —
# blunts enumeration/abuse on writes that create records.
PUBLIC_WRITE_RATE_WINDOW_MS=900000   # window length in ms (900000 = 15 min)
PUBLIC_WRITE_RATE_MAX=20             # max requests per IP per window

# ── Storage (self-hosted media per V2.2 spec) ───────────────
STORAGE_KIND=local
STORAGE_LOCAL_ROOT=./media
CDN_BASE_URL=
MEDIA_MAX_FILE_SIZE_MB=200

# ── FFmpeg ──────────────────────────────────────────────────
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe

# ── Payment Gateways ────────────────────────────────────────
# Implementation status (2026-06-14): all 4 implemented (service + webhook
# verify + confirm → resolves in Sales). Each is env-gated: blank keys → that
# gateway's calls return a clean 503 and its webhooks log-only.
#   Paystack — initialize / verify / charge-authorization; HMAC-SHA512 webhook.
#   OPay     — Cashier initialize / status verify; HMAC-SHA512 webhook.
#   Nomba    — OAuth + checkout initialize / verify; HMAC-SHA256 webhook.
#   Stripe   — Checkout Session + retrieve; constructEvent webhook (raw body).
# Confirm handlers resolve brand+order_id from transaction metadata, re-verify
# server-side, and record idempotently. Each confirmed payment captures the
# per-gateway fee from business_config.payment_gateway_fees and books it to the
# gateway's 551x GL account (§6.6); Stripe captures paid_currency/amount/fx for
# realised-FX. Stripe requires metadata.amount_ngn.
# (Payment INITIATION at checkout — choosing a gateway — is the front-end's job;
#  these are the gateway clients + the inbound confirmation pipeline.)
# Paystack (NGN) — ✅
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
# OPay (NGN) — ✅  (Cashier API)
OPAY_PUBLIC_KEY=
OPAY_PRIVATE_KEY=
OPAY_MERCHANT_ID=
OPAY_BASE_URL=https://liveapi.opaycheckout.com
# Nomba (NGN, online + POS) — ✅  (OAuth client-credentials)
NOMBA_CLIENT_ID=
NOMBA_API_KEY=                       # = Nomba client secret
NOMBA_ACCOUNT_ID=
NOMBA_BASE_URL=https://api.nomba.com
# Stripe (international) — ✅
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Logistics ───────────────────────────────────────────────
CHOWDECK_API_KEY=
GIGL_API_KEY=
DHL_API_KEY=                          # international / cross-border (not yet wired)

# ── Communication ───────────────────────────────────────────
# Meta WhatsApp Cloud API
META_WA_PHONE_ID=
META_WA_TOKEN=
META_WA_VERIFY_TOKEN=
# Instagram Graph API
META_IG_ACCESS_TOKEN=
META_GRAPH_VERIFY_TOKEN=

# ── Social posting (V2.2 §6.14) ─────────────────────────────
# Status (2026-06-14): outbound publishing implemented for all 4 platforms
# (Instagram, Facebook, TikTok, YouTube) via src/services/social-publisher.
# Each is env-gated: blank creds → that platform's publish/metrics return a
# clean 503 and the post is marked 'failed'. One account per platform.
#   instagram → Meta Graph: media container → media_publish (image/reel)
#   facebook  → Meta Graph Page: /photos | /videos | /feed
#   tiktok    → Content Posting API (PULL_FROM_URL video init)
#   youtube   → Data API v3 videos.insert (multipart upload from media URL)
META_GRAPH_VERSION=v21.0
META_IG_USER_ID=                     # IG Business account id (publish target)
META_FB_PAGE_ID=
META_FB_PAGE_TOKEN=                  # Page access token — used for FB + IG publish
TIKTOK_ACCESS_TOKEN=
TIKTOK_BASE_URL=https://open.tiktokapis.com
YOUTUBE_ACCESS_TOKEN=               # OAuth token with youtube.upload scope
YOUTUBE_BASE_URL=https://www.googleapis.com

# SMTP (transactional email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── SMS (Twilio) — optional retention fallback channel ──────
# Unset → sms.service no-ops (returns "skipped"). Used by retention workflows
# when a customer has no email / WhatsApp on file.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=                          # +E.164 number or a Messaging Service SID

# ── Marketing / paid ads (V2.2 §6.15 — Google Ads + Meta) ───
# Live spend sync + campaign push. App-level creds here; per-ad-account OAuth
# tokens are stored AES-encrypted on shared.ad_accounts. Blank for a network →
# its pull/push returns a clean 503 and the nightly sync skips it.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=         # MCC / manager account id (digits only), optional
GOOGLE_ADS_API_VERSION=v17
GOOGLE_ADS_BASE_URL=https://googleads.googleapis.com
GOOGLE_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
META_MARKETING_API_KEY=               # optional system-user token; per-account tokens preferred
META_ADS_APP_SECRET=                  # optional, enables appsecret_proof on Meta calls

# ── E-Commerce (WooCommerce sync) ───────────────────────────
WOOCOMMERCE_URL=
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=

# ── Geolocation ─────────────────────────────────────────────
MAXMIND_DB_PATH=./data/GeoLite2-Country.mmdb

# ── AI (per V2.2 §8.1) ──────────────────────────────────────
# DeepSeek (LLM)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# Groq (Whisper transcription)
GROQ_API_KEY=
# OpenAI (embeddings only)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# AI budget enforcement
AI_MONTHLY_SOFT_CAP_NGN=75000
AI_MONTHLY_HARD_CAP_NGN=80000

# ── Speech-to-text (Whisper) — Praxis voice input (X-2) ─────
# Unset / "none" → transcription no-ops. MEDIA_BASE_URL allow-lists the origin
# audio assets may be fetched from (SSRF guard on the transcription fetch).
TRANSCRIPTION_PROVIDER=none          # none | openai | groq | <provider>
TRANSCRIPTION_API_KEY=
TRANSCRIPTION_API_BASE_URL=
TRANSCRIPTION_MODEL=                  # e.g. whisper-1 | whisper-large-v3
MEDIA_BASE_URL=                      # e.g. https://media.pixiegirl.example

# ── Observability ───────────────────────────────────────────
SENTRY_DSN=
ENABLE_REQUEST_LOGGING=true
ENABLE_AUDIT_LOG=true

# ── PDF rendering (J-7 / X-1 — headless Chromium via puppeteer) ──
PDF_ENABLED=true
PUPPETEER_SKIP_DOWNLOAD=true
PUPPETEER_EXECUTABLE_PATH=           # e.g. /usr/bin/chromium; blank = puppeteer's bundled Chromium
PDF_RENDER_TIMEOUT_MS=30000

# ── FX rate provider (J-3) ──────────────────────────────────
# none → fx-rates cron no-ops. exchangerate_host has a free no-key tier;
# openexchangerates / fixer require FX_API_KEY.
FX_PROVIDER=none                     # none | openexchangerates | exchangerate_host | fixer
FX_API_KEY=
FX_API_BASE_URL=
FX_BASE_CURRENCY=NGN
FX_BUFFER_PCT=0                      # 0..1 (e.g. 0.02 = +2% buffer over market)

# ── Embeddings / RAG vendor (J-8) ───────────────────────────
# none → ai-embed worker + Praxis RAG retrieval skip.
EMBEDDINGS_PROVIDER=none             # none | openai | deepseek | voyage
EMBEDDINGS_API_KEY=
EMBEDDINGS_API_BASE_URL=
EMBEDDINGS_MODEL=text-embedding-3-small

# ── Praxis live orchestrator (X-2) ──────────────────────────
# Off by default. When on AND the PRAXIS_LLM_VENDOR row is configured in AI
# Control (ai_vendor_credentials), Praxis runs live (RAG → LLM → propose action).
PRAXIS_ORCHESTRATOR_ENABLED=false
PRAXIS_LLM_VENDOR=deepseek           # which ai_vendor_credentials row backs the chat LLM
PRAXIS_RAG_TOP_K=6
PRAXIS_MAX_TOOLS=40

# ── Workers ─────────────────────────────────────────────────
ENABLE_WORKERS=true                  # run BullMQ consumers + crons in-process

# ── Feature flags ───────────────────────────────────────────
FEATURE_MANUAL_PAYMENTS_ENABLED=false
FEATURE_PRAXIS_VOICE_ENABLED=true
FEATURE_UGC_INGESTION_ENABLED=true

# ── Cron schedules (in your tz) ─────────────────────────────
TZ=Africa/Lagos
CRON_DAILY_AI_BRIEFING=0 7 * * *
CRON_WEEKLY_SALES_REPORT=0 20 * * 6
CRON_WEEKLY_CUSTOMER_REPORT=0 20 * * 6
CRON_LAYAWAY_ABANDONMENT_CHECK=0 2 * * *
CRON_FX_RATE_REFRESH=0 6 * * *
CRON_LOW_STOCK_ALERTS=0 8,14 * * *
CRON_SUBSCRIPTION_RENEWAL_REMINDERS=0 9 * * *
CRON_RETENTION_WORKFLOWS=0 3 * * *
CRON_AI_EMBEDDINGS_REFRESH=0 4 * * *
# Web Push (VAPID) — generate once with:
#   node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(JSON.stringify(k));"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@pixiegirl.com
