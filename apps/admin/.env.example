# Admin frontend environment.
#
# Default points at a relative /api/v1 path so the Vite dev proxy
# (configured in vite.config.ts) forwards /api/* to the backend
# (default target: http://localhost:7000, matching the backend's
# default PORT). Set VITE_API_PROXY_TARGET to point the proxy at a
# different host/port. In production builds, set VITE_API_URL to an
# absolute URL of the deployed backend.
VITE_API_URL=/api/v1
# VITE_API_PROXY_TARGET=http://localhost:7000

# Google Maps / Places browser key for address autocomplete on the public
# Walk-in + Online-QR forms.
#
# PREFERRED (production): set GOOGLE_MAPS_API_KEY on the BACKEND. The admin app
# fetches it at runtime from GET /api/public/config, so it works without
# rebuilding this bundle. Setting it below instead bakes it in at build time
# (handy for local dev) and overrides the runtime value.
# VITE_GOOGLE_PLACES_API_KEY=
