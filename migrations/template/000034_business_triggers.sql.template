-- ╔════════════════════════════════════════════════════════════════════╗
-- ║ PRODUCTION: roll up cost_components into production_runs totals    ║
-- ╚════════════════════════════════════════════════════════════════════╝

CREATE OR REPLACE FUNCTION {{BUSINESS}}.fn_production_run_recompute_totals()
RETURNS TRIGGER
LANGUAGE plpgsql AS $$
DECLARE
  v_run_id UUID;
BEGIN
  v_run_id := COALESCE(NEW.run_id, OLD.run_id);
  UPDATE {{BUSINESS}}.production_runs r
     SET total_factory_cost_ngn = COALESCE((SELECT SUM(amount_ngn) FROM {{BUSINESS}}.cost_components
                                              WHERE run_id = v_run_id
                                                AND cost_type IN ('factory_unit_cost','factory_overhead','raw_hair')),0),
         total_freight_ngn      = COALESCE((SELECT SUM(amount_ngn) FROM {{BUSINESS}}.cost_components
                                              WHERE run_id = v_run_id
                                                AND cost_type = 'freight_international'),0),
         total_customs_ngn      = COALESCE((SELECT SUM(amount_ngn) FROM {{BUSINESS}}.cost_components
                                              WHERE run_id = v_run_id
                                                AND cost_type IN ('customs_duty','customs_clearing_fee','port_storage')),0),
         total_3pl_lagos_ngn    = COALESCE((SELECT SUM(amount_ngn) FROM {{BUSINESS}}.cost_components
                                              WHERE run_id = v_run_id
                                                AND cost_type = '3pl_lagos'),0),
         total_styling_ngn      = COALESCE((SELECT SUM(amount_ngn) FROM {{BUSINESS}}.cost_components
                                              WHERE run_id = v_run_id
                                                AND cost_type = 'styling_intercompany'),0),
         total_packaging_ngn    = COALESCE((SELECT SUM(amount_ngn) FROM {{BUSINESS}}.cost_components
                                              WHERE run_id = v_run_id
                                                AND cost_type = 'packaging'),0),
         total_wastage_ngn      = COALESCE((SELECT SUM(amount_ngn) FROM {{BUSINESS}}.cost_components
                                              WHERE run_id = v_run_id
                                                AND cost_type IN ('wastage','samples')),0),
         total_other_ngn        = COALESCE((SELECT SUM(amount_ngn) FROM {{BUSINESS}}.cost_components
                                              WHERE run_id = v_run_id
                                                AND cost_type IN ('quality_inspection','misc')),0),
         updated_at             = now()
   WHERE r.run_id = v_run_id;
  RETURN COALESCE(NEW, OLD);
END;
$$;

CREATE TRIGGER trg_{{BUSINESS}}_production_run_recompute
  AFTER INSERT OR UPDATE OR DELETE ON {{BUSINESS}}.cost_components
  FOR EACH ROW EXECUTE FUNCTION {{BUSINESS}}.fn_production_run_recompute_totals();

-- ╔════════════════════════════════════════════════════════════════════╗
-- ║ SERVICE JOB: auto-create task when assigned (V2.2 §6.24)           ║
-- ╚════════════════════════════════════════════════════════════════════╝

CREATE OR REPLACE FUNCTION {{BUSINESS}}.fn_service_job_create_task()
RETURNS TRIGGER
LANGUAGE plpgsql AS $$
DECLARE
  v_task_id UUID;
BEGIN
  -- Only when newly assigned to a staff member (stylists are external; tasks are staff)
  IF NEW.assigned_staff_user_id IS NOT NULL
     AND (OLD IS NULL OR OLD.assigned_staff_user_id IS DISTINCT FROM NEW.assigned_staff_user_id)
     AND NEW.task_id IS NULL THEN
    INSERT INTO shared.tasks
      (business, title, description, status, priority, assigned_to, due_at,
       reference_type, reference_id, created_by)
    VALUES
      ('{{BUSINESS}}',
       'Service Job ' || NEW.job_number,
       'Complete service job. Status: ' || NEW.status,
       'today',
       'normal',
       NEW.assigned_staff_user_id,
       NEW.expected_completion_at,
       'service_job',
       NEW.job_id,
       NEW.created_by)
    RETURNING task_id INTO v_task_id;
    -- Attach back the task_id
    NEW.task_id := v_task_id;
  END IF;
  RETURN NEW;
END;
$$;

CREATE TRIGGER trg_{{BUSINESS}}_service_job_create_task
  BEFORE INSERT OR UPDATE OF assigned_staff_user_id ON {{BUSINESS}}.service_jobs
  FOR EACH ROW EXECUTE FUNCTION {{BUSINESS}}.fn_service_job_create_task();

-- ╔════════════════════════════════════════════════════════════════════╗
-- ║ DOCUMENT NUMBERING: atomic increment helper                        ║
-- ║ (Service-layer calls this function; not a trigger but lives here)  ║
-- ╚════════════════════════════════════════════════════════════════════╝

CREATE OR REPLACE FUNCTION {{BUSINESS}}.fn_next_document_number(p_document_type TEXT)
RETURNS TEXT
LANGUAGE plpgsql AS $$
DECLARE
  v_row    shared.document_numbering%ROWTYPE;
  v_result TEXT;
BEGIN
  -- SELECT FOR UPDATE prevents duplicate issuance under concurrent load
  SELECT * INTO v_row
    FROM shared.document_numbering
   WHERE business = '{{BUSINESS}}' AND document_type = p_document_type
     FOR UPDATE;

  IF NOT FOUND THEN
    RAISE EXCEPTION 'No document_numbering row for ({{BUSINESS}}, %)', p_document_type;
  END IF;

  v_result := v_row.prefix || '-' || LPAD(v_row.next_number::text, v_row.padding, '0');

  UPDATE shared.document_numbering
     SET next_number = next_number + 1
   WHERE seq_id = v_row.seq_id;

  RETURN v_result;
END;
$$;

-- ╔════════════════════════════════════════════════════════════════════╗
-- ║ KPI WEIGHTS MUST SUM TO 100 (Amendment A-3)                        ║
-- ║ V2.2 §6.11 — "Weighted Performance KPIs: 40 / 25 / 20 / 15".       ║
-- ║ Without this trigger, admin could add a 5th KPI and silently push  ║
-- ║ the sum to 110. The performance review math would then be wrong   ║
-- ║ in subtle, undetectable ways. Trigger blocks the write.            ║
-- ╚════════════════════════════════════════════════════════════════════╝

CREATE OR REPLACE FUNCTION {{BUSINESS}}.fn_kpi_weights_sum_to_100()
RETURNS TRIGGER
LANGUAGE plpgsql AS $$
DECLARE
  v_total NUMERIC(8,2);
BEGIN
  -- Compute total weight across ACTIVE KPIs after this change
  SELECT COALESCE(SUM(weight_pct), 0)
    INTO v_total
    FROM {{BUSINESS}}.performance_kpi_definitions
   WHERE is_active = true;

  -- On INSERT/UPDATE the new row may already be in the table (AFTER trigger
  -- timing) so we don't add it here. On DELETE the row is gone.
  -- We only enforce when not in the middle of an active-deactivate flip.
  IF v_total <> 100.00 THEN
    RAISE EXCEPTION
      'KPI weights must sum to exactly 100.00 across active KPIs (currently %); add/remove/edit weights together as a set',
      v_total;
  END IF;
  RETURN NULL;
END;
$$;

CREATE CONSTRAINT TRIGGER trg_{{BUSINESS}}_kpi_weights_sum
  AFTER INSERT OR UPDATE OR DELETE ON {{BUSINESS}}.performance_kpi_definitions
  DEFERRABLE INITIALLY DEFERRED
  FOR EACH ROW EXECUTE FUNCTION {{BUSINESS}}.fn_kpi_weights_sum_to_100();

-- ============================================================
-- All triggers and helpers above are no-table-add statements.
-- ============================================================
