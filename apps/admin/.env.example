# Admin frontend environment.
#
# Default points at a relative /api/v1 path so the Vite dev proxy
# (configured in vite.config.ts) forwards /api/* to the backend
# (default target: http://localhost:4000). Set VITE_API_PROXY_TARGET to
# point the proxy at a different host. In production builds, set
# VITE_API_URL to an absolute URL of the deployed backend.
VITE_API_URL=/api/v1
# VITE_API_PROXY_TARGET=http://localhost:4000
