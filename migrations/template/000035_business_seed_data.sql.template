-- ╔════════════════════════════════════════════════════════════════════╗
-- ║ FISCAL PERIODS — current year                                      ║
-- ╚════════════════════════════════════════════════════════════════════╝

DO $$
DECLARE
  v_year SMALLINT := EXTRACT(YEAR FROM CURRENT_DATE)::SMALLINT;
  v_month SMALLINT;
  v_start DATE;
  v_end   DATE;
BEGIN
  FOR v_month IN 1..12 LOOP
    v_start := make_date(v_year, v_month, 1);
    v_end   := (v_start + INTERVAL '1 month - 1 day')::date;
    INSERT INTO {{BUSINESS}}.fiscal_periods
      (fiscal_year, period_number, period_name, starts_on, ends_on, status)
    VALUES
      (v_year, v_month,
       to_char(v_start, 'Mon YYYY'),
       v_start, v_end,
       CASE
         WHEN v_end < CURRENT_DATE - INTERVAL '60 days' THEN 'closed'
         WHEN v_end < CURRENT_DATE THEN 'open'
         WHEN v_start <= CURRENT_DATE AND v_end >= CURRENT_DATE THEN 'open'
         ELSE 'future'
       END)
    ON CONFLICT (fiscal_year, period_number) DO NOTHING;
  END LOOP;
  -- Period 13 (year-end adjustments)
  INSERT INTO {{BUSINESS}}.fiscal_periods
    (fiscal_year, period_number, period_name, starts_on, ends_on, status, is_year_end)
  VALUES
    (v_year, 13, 'Year-End Adjustments ' || v_year,
     make_date(v_year, 12, 31), make_date(v_year, 12, 31), 'future', true)
  ON CONFLICT (fiscal_year, period_number) DO NOTHING;
END;
$$;

