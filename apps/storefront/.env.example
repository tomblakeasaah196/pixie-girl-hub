# Pixie Girl Hub — Storefront Website env
# Copy to .env and fill in. NEVER commit real secrets.

# Hub backend base URL (server-side SSR fetches go here).
HUB_API_URL=http://localhost:7000

# Dev-only Vite proxy target for /api and /media (defaults to HUB_API_URL host).
VITE_API_PROXY_TARGET=http://localhost:7000

# Brand resolution. In production brand is resolved from the request HOST
# (see src/lib/brand.ts). For local dev, force a brand:
#   - DEFAULT_BRAND is the SSR fallback when the host doesn't match a known map.
#   - VITE_STOREFRONT_BRAND overrides on the client for `vite dev`.
DEFAULT_BRAND=pixiegirl
VITE_STOREFRONT_BRAND=pixiegirl

# NO SUPABASE. The Aura reference used VITE_SUPABASE_* — those are intentionally
# absent. If anything asks for them, it has not been ported off Supabase yet.
